  <!-- AOS Animation Library -->
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  
  <!-- Initialize AOS with smooth scrolling -->
  <script>
    AOS.init({
      duration: 800,
      easing: 'ease-out-cubic',
      once: false,
      mirror: true,
      offset: 50,
      delay: 0
    });
    
               // Progress indicator functionality
           document.addEventListener('DOMContentLoaded', function() {
             const sections = document.querySelectorAll('[data-aos]');
             const progressCircle = document.querySelector('.progress-ring-circle');
             const character = document.querySelector('.character');
             const journeyGates = document.querySelectorAll('.journey-gate');

             function updateProgress() {
               const scrollTop = window.pageYOffset;
               const docHeight = document.body.offsetHeight - window.innerHeight;
               const scrollPercent = (scrollTop / docHeight) * 100;

               // Update circular progress
               const radius = 50;
               const circumference = 2 * Math.PI * radius;
               const offset = circumference - (scrollPercent / 100) * circumference;
               progressCircle.style.strokeDasharray = circumference;
               progressCircle.style.strokeDashoffset = offset;

               // Update gate states based on scroll progress
               const totalGates = journeyGates.length;
               const activeGateIndex = Math.floor((scrollPercent / 100) * totalGates);

               journeyGates.forEach((gate, index) => {
                 if (index <= activeGateIndex) {
                   gate.classList.add('active');
                 } else {
                   gate.classList.remove('active');
                 }
               });

               // Add walking animation to character
               if (scrollPercent > 0 && scrollPercent < 100) {
                 character.classList.add('walking');
               } else {
                 character.classList.remove('walking');
               }
             }

             window.addEventListener('scroll', updateProgress);
             updateProgress();
           });
  </script>
